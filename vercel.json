{
  "version": 2,
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/(?!static/)(.*)$",
      "dest": "/index.html"
    }
  ]
}